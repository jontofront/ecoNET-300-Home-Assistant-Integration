{
  "services": {
    "reset_fuel_meter": {
      "name": "Reset fuel meter",
      "description": "Resets the fuel consumption meter to zero."
    },
    "calibrate_fuel_meter": {
      "name": "Calibrate fuel meter",
      "description": "Sets the fuel consumption meter to a specific value.",
      "fields": {
        "value": {
          "name": "Value",
          "description": "The value to set the meter to (in kg)."
        }
      }
    },
    "get_schedule": {
      "name": "Get schedule",
      "description": "Retrieves a decoded boiler schedule from the device.",
      "fields": {
        "schedule_type": {
          "name": "Schedule type",
          "description": "Schedule to retrieve (e.g. water_heater, boiler_work, mixer_1)."
        },
        "weekday": {
          "name": "Weekday",
          "description": "Day of the week. Returns all days if omitted."
        }
      }
    }
  },
  "exceptions": {
    "parameter_locked": {
      "message": "Cannot change value: {lock_reason}"
    },
    "boiler_control_failed": {
      "message": "Failed to control boiler: {error}"
    },
    "switch_turn_on_failed": {
      "message": "Failed to turn on switch: {error}"
    },
    "switch_turn_off_failed": {
      "message": "Failed to turn off switch: {error}"
    },
    "heater_mode_change_failed": {
      "message": "Failed to change heater mode to {mode}"
    },
    "select_change_failed": {
      "message": "Failed to change select option: {error}"
    },
    "number_set_failed": {
      "message": "Failed to set value: {error}"
    },
    "api_communication_error": {
      "message": "Error communicating with device: {error}"
    },
    "device_unavailable": {
      "message": "Device is unavailable: {error}"
    }
  },
  "issues": {
    "connection_failed": {
      "title": "Connection to ecoNET300 device failed",
      "fix_flow": {
        "step": {
          "confirm": {
            "title": "Update connection settings",
            "description": "Unable to connect to your ecoNET300 device at **{host}** after {failures} consecutive attempts.\n\nUpdate your connection settings to restore connectivity.",
            "data": {
              "host": "Host",
              "username": "Username",
              "password": "Password"
            }
          }
        }
      }
    }
  },
  "config": {
    "step": {
      "user": {
        "data": {
          "host": "Host",
          "username": "Username",
          "password": "Password"
        }
      },
      "reconfigure": {
        "title": "Reconfigure ecoNET300",
        "description": "Update connection settings for your ecoNET300 device. This is useful if your device IP address has changed.",
        "data": {
          "host": "Host",
          "username": "Username",
          "password": "Password"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect",
      "invalid_auth": "Invalid authentication",
      "unknown": "Unexpected error"
    },
    "abort": {
      "already_configured": "Device is already configured",
      "reconfigure_failed": "Reconfiguration failed. Please try again."
    }
  },
  "options": {
    "step": {
      "init": {
        "menu_options": {
          "connection_settings": "Connection Settings",
          "custom_entities": "Custom Entities",
          "device_settings": "Device settings",
          "diagnostics": "Generate diagnostics report",
          "polling_settings": "Polling settings"
        }
      },
      "device_settings": {
        "title": "Device settings",
        "description": "Choose how entities are grouped into devices. Split keeps separate devices per component (boiler, mixers, lambda, ecoSTER, etc.). Single merges everything into one device.",
        "data": {
          "device_grouping": "Device grouping"
        },
        "data_description": {
          "device_grouping": "Split (separate devices) or Single (one merged device). Entity IDs are unchanged either way."
        }
      },
      "polling_settings": {
        "data": {
          "poll_reg_params": "regParams polling interval (seconds) — live sensor values",
          "poll_sys_params": "sysParams polling interval (seconds) — controller metadata",
          "poll_edit_params": "editParams polling interval (seconds, 0 to disable) — editable parameters catalog/values"
        }
      },
      "connection_settings": {
        "title": "Connection Settings",
        "description": "Update your ecoNET300 connection settings",
        "data": {
          "host": "Host",
          "username": "Username",
          "password": "Password"
        }
      },
      "diagnostics": {
        "title": "Generate diagnostics report",
        "description": "Probe the device, write a redacted JSON report to homeassistant.log (marker: ECONET300_DIAGNOSTICS_REPORT) and raise a persistent notification with a short summary. Use this to attach a complete report to a GitHub issue."
      },
      "custom_entities": {
        "title": "Custom Entities",
        "description": "Select the API endpoint to browse for custom entities.",
        "data": {
          "endpoint": "API endpoint"
        }
      },
      "select_params": {
        "title": "Select Parameters",
        "description": "Choose parameters to expose as entities. Already-mapped static parameters are excluded.",
        "data": {
          "selected_params": "Available parameters"
        }
      },
      "configure_entity": {
        "title": "Configure Entity",
        "description": "Configure entity for {key} from {source}.",
        "data": {
          "name": "Entity name",
          "component": "Device group",
          "entity_type": "Entity type",
          "entity_category": "Entity category"
        }
      },
      "configure_sensor": {
        "title": "Configure Sensor",
        "description": "Configure sensor properties for \"{name}\".",
        "data": {
          "native_unit": "Unit of measurement",
          "device_class": "Device class",
          "precision": "Display precision"
        }
      }
    },
    "error": {
      "cannot_connect": "Failed to connect",
      "invalid_auth": "Invalid authentication",
      "unknown": "Unexpected error"
    },
    "abort": {
      "no_unmapped_params": "No unmapped parameters available for the selected endpoint."
    }
  },
